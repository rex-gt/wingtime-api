# ===========================================
# AeroBook API Environment Configuration
# ===========================================
# Copy this file to .env and update with your values
# .env is gitignored and safe for secrets

# Database Configuration (local development)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=flying_club
DB_PASSWORD=your_db_password_change_this
DB_PORT=5432

# Server Configuration
PORT=3000
NODE_ENV=development

# ===========================================
# Production Configuration (Railway)
# ===========================================
# These values are used by scripts/railway/*.sh
# to set up your production environment.

# App Configuration
APP_URL=https://your-app-domain.com
ALLOWED_ORIGINS=https://your-app-domain.com

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=YourApp <noreply@your-domain.com>

# JWT Secrets
# For local dev, use any string. For production, secrets are auto-generated.
JWT_SECRET=your-jwt-secret-here-generate-with-openssl-rand-base64-32
RESET_TOKEN_SECRET=your-reset-token-secret-generate-with-openssl-rand-base64-32

# ===========================================
# Optional Configuration
# ===========================================

# SSL/TLS (local development only)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt

# Email configuration (required for password reset)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@wingtime.com

# Frontend URL (used to build password reset links)
FRONTEND_URL=http://localhost:5173
