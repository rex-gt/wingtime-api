DB_USER=postgres
DB_HOST=localhost
DB_NAME=flying_club
DB_PASSWORD=password
DB_PORT=5432
JWT_SECRET=your_jwt_secret_key_change_this
# Separate secret for password-reset tokens (recommended; falls back to JWT_SECRET if not set)
RESET_TOKEN_SECRET=your_reset_token_secret_change_this
PORT=3000
# SSL/TLS configuration (optional - when set, the server will use HTTPS)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
# Email (SMTP) configuration - required for welcome emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@wingtime.app
# Frontend application URL used in password-reset links
APP_URL=http://localhost:5173
